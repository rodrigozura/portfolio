# ─── Application ────────────────────────────────────────────
# DB_HOST debe apuntar al servicio de base de datos.
# En Docker Compose local: db
# En Proxmox: 172.16.90.158
DB_HOST=db

# ─── MariaDB ────────────────────────────────────────────────
MARIADB_ROOT_PASSWORD=tu_root_password_seguro
MARIADB_DATABASE=blogdb
MARIADB_USER=bloguser
MARIADB_PASSWORD=tu_password_seguro

# ─── Deployment base path ───────────────────────────────────
# Set this when the app is served under a sub-path.
# Leave empty (or omit) when deployed at web root (/).
# Example for NAP Proxmox deployment: APP_BASE_PATH=/38249507
APP_BASE_PATH=
